# Extract.io SaaS - Environment Variables Example
DATABASE_URL=sqlite:///./extract_io.db

# === JWT Authentication ===
JWT_SECRET_KEY=yoursecret-key
CLERK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_SECRET_KEY=sk_test_...
CLERK_API_URL=https://api.clerk.com/v1

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# === Application ===
APP_ENV=development
APP_DEBUG_MODE=false
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === Security Keys ===
API_KEY_PEPPER=change_me_with_a_random_64_char_string
